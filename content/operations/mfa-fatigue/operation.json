      "id": "s1",
      "order": 1,
      "prompt": "The user received 14 MFA push prompts in 6 minutes. Triage.",
      "console_focus": "siem",
      "expected_verdict": "tp",
      "expected_mitre": ["T1110.001"],
      "expected_indicators": ["push-flood", "auto-approved"],
      "hints": [
        { "after_seconds": 30, "text": "Did the user approve one of the prompts?" }
      ],
      "hints_after_seconds": 30,
      "hints_interval_seconds": 30,
      "hint_penalty_percent": 5
    },
    {
      "id": "s2",
      "order": 2,
      "prompt": "Was the account compromised after the flood?",
      "console_focus": "siem",
      "expected_verdict": "tp",
      "expected_mitre": ["T1078"],
      "expected_indicators": ["Mail.Read.All", "consent-grant"],
      "hints": [
        { "after_seconds": 45, "text": "Look for OAuth scope grants." }
      ],
      "hints_after_seconds": 45,
      "hints_interval_seconds": 60,
