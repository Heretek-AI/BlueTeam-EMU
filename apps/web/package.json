{
  "name": "@blueteam-emu/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 5173",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "playwright test",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --threshold warning",
    "lint": "echo 'no lint configured'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx ./src/lib/server/db/migrate.ts",
    "db:seed": "tsx ./src/lib/server/db/seed.ts",
    "reset-user": "tsx ./scripts/reset-user.ts",
    "seed-demo": "tsx ./scripts/seed-demo.ts"
  },
  "dependencies": {
    "@sveltejs/adapter-node": "^5.2.9",
    "@sveltejs/kit": "^2.8.0",
    "better-sqlite3": "^11.3.0",
    "drizzle-orm": "^0.45.2",
    "svelte": "^5.1.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "drizzle-kit": "^0.28.1",
    "svelte-check": "^4.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
