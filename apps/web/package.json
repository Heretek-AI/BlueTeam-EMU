  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22.9.0",
    "@types/sql.js": "^1.4.9",
    "svelte-check": "^4.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
